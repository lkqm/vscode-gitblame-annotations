{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Watch",
			"type": "npm",
			"script": "watch",
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"showReuseMessage": false
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}