{
    "name": "gitblame-annotations",
    "displayName": "Git Blame Annotations",
    "description": "Display git blame in editor gutter like JetBrains IDEs",
    "version": "0.2.3",
    "publisher": "lkqm",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/lkqm/vscode-gitblame-annotations.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "SCM Providers"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "icon": "logo.png",
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "git.blame.toggle",
                "title": "Toggle Annotations"
            },
            {
                "command": "git.blame.show",
                "title": "Annotate with Git Blame"
            },
            {
                "command": "git.blame.hide",
                "title": "Close Annotations"
            }
        ],
        "menus": {
            "editor/lineNumber/context": [
                {
                    "command": "git.blame.show",
                    "when": "gitblame.showMenuState"
                },
                {
                    "command": "git.blame.hide",
                    "when": "gitblame.hideMenuState"
                }
            ]
        },
        "keybindings": [
            {
                "command": "git.blame.toggle",
                "key": "ctrl+alt+b",
                "mac": "cmd+alt+b",
                "when": "editorTextFocus"
            },
            {
                "command": "git.blame.hide",
                "key": "escape",
                "when": "editorTextFocus && gitblame.hideMenuState"
            }
        ],
        "configuration": {
            "title": "Git Blame Annotations",
            "properties": {
                "gitblame.mergeCommitLines": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show annotation only on the first line of each commit block, leaving subsequent lines blank."
                },
                "gitblame.showCommitMessage": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show the commit message in the blame gutter (widens the gutter)."
                },
                "gitblame.relativeTimestamps": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show relative timestamps (e.g. '7 months ago') instead of absolute dates."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/node": "^16.18.126",
        "@types/vscode": "^1.80.0",
        "@typescript-eslint/eslint-plugin": "^5.42.0",
        "@typescript-eslint/parser": "^5.42.0",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^8.26.0",
        "typescript": "^4.8.4"
    }
}
